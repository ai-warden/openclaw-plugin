  },
  "homepage": "https://prompt-shield.se/openclaw",
  "dependencies": {
    "ai-warden": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
