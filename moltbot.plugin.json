{
  "id": "openclaw-plugin",
  "name": "AI-Warden Security",
  "version": "1.1.0",
  "description": "Multi-layer security validation for AI agents",
  "author": "AI-Warden",
  "license": "MIT",
  "homepage": "https://github.com/ai-warden/openclaw-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-warden/openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/ai-warden/openclaw-plugin/issues"
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "apiKey": {
        "type": "string"
      },
      "layers": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "content": { "type": "boolean" },
          "channel": { "type": "boolean" },
          "preLlm": { "type": "boolean" },
          "toolArgs": { "type": "boolean" },
          "subagents": { "type": "boolean" },
          "output": { "type": "boolean" }
        }
      },
      "policy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "blockThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1000
          },
          "warnThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1000
          },
          "failOpen": { "type": "boolean" }
        }
      },
      "enableStats": { "type": "boolean" }
    }
  }
}
